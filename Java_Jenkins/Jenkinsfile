pipeline {
  agent {
    // Changed to a Docker image that includes Java (OpenJDK 11)
    docker { image 'maven:3.8.6-openjdk-11' }
  }
  stages {
    stage('Prepare Java Code') {
      steps {
        sh 'mkdir -p src/main/java'
        sh """
}
          cat <<EOF > src/main/java/HelloWorld.java
          public class HelloWorld {
            public static void main(String[] args) {
              System.out.println("Hello, World!");
            }
          }
          EOF
        """
      }
    }
    stage('Compile and Run Java') {
      steps {
        // Compile the Java source file
        sh 'javac src/main/java/HelloWorld.java'
        // Run the compiled Java class
        sh 'java -cp src/main/java HelloWorld'
      }
    }
  }
}
